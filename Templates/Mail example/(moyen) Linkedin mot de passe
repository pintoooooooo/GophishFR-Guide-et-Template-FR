<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Strict//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-strict.dtd">
<html lang="fr" xmlns="http://www.w3.org/1999/xhtml">
<head><meta http-equiv="Content-Type" content="text/html; charset=utf-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<title>LinkedIn</title>
	<style type="text/css">@media screen and (max-width: 540px) {
            .email-container { width: 100% !important; }
        }
	</style>
</head>
<body style="margin:0; padding:0; background-color:#f3f3f2; -webkit-text-size-adjust:100%;">
<table bgcolor="#f3f3f2" border="0" cellpadding="0" cellspacing="0" role="presentation" width="100%">
	<tbody>
		<tr>
			<td align="center" style="padding: 20px 0;">
			<table bgcolor="#ffffff" border="0" cellpadding="0" cellspacing="0" class="email-container" role="presentation" style="border-radius: 4px; overflow: hidden;" width="540">
				<tbody>
					<tr>
						<td style="padding: 20px 30px 10px 30px;"><a href="https://www.linkedin.com" target="_blank"><img alt="LinkedIn" src="cid:linkedin.png" style="display: block; border: 0px; width: 85px;" /> </a></td>
					</tr>
					<tr>
						<td align="center" style="padding: 40px 30px 30px 30px;">
						<h1 style="margin: 0 0 30px 0; font-family: -apple-system, system-ui, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Helvetica, Arial, sans-serif; font-size: 24px; line-height: 28px; color: rgba(0,0,0,0.9); font-weight: 400; text-align: center;">Bonjour {{.FirstName}}, r&eacute;initialisez votre mot de passe</h1>

						<div style="margin-bottom: 30px; text-align: center;"><a href="{{.URL}}" style="text-decoration: none; display: inline-block;" target="_blank"><img alt="Réinitialiser le mot de passe" src="cid:linbouton.png" style="display: block; border: 0px; max-width: 100%;" /> </a></div>

						<p style="margin: 30px 0 0 0; font-family: -apple-system, system-ui, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; font-size: 14px; line-height: 20px; color: rgba(0,0,0,0.6); text-align: center;">Si vous n&#39;avez pas demand&eacute; ce changement, vous pouvez ignorer cet e-mail.</p>
						</td>
					</tr>
					<tr>
						<td style="padding: 0 30px;">
						<hr style="border: none; border-top: 1px solid #e0e0e0; margin: 0;" /></td>
					</tr>
					<tr>
						<td style="padding: 20px 30px 40px 30px; font-family: -apple-system, system-ui, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; font-size: 12px; line-height: 16px; color: rgba(0,0,0,0.6); text-align: center;">
						<p style="margin: 0 0 10px 0;">Vous recevez des notifications relatives &agrave; la s&eacute;curit&eacute; de votre compte LinkedIn.</p>

						<p style="margin: 0;">&copy; 2026 LinkedIn Ireland Limited, Wilton Plaza, Wilton Place, Dublin 2, Irlande.</p>
						</td>
					</tr>
				</tbody>
			</table>
			</td>
		</tr>
	</tbody>
</table>

<div style="display:none !important; visibility:hidden; opacity:0; color:transparent; height:0; width:0;">{{.Tracker}}</div>
</body>
</html>
